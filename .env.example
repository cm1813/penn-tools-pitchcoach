# ─────────────────────────────────────────────────────────────────────────────
# PennTools environment variables
# Copy to .env.local for local development. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Database (Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/penntools?schema=public"

# LLM providers (only one needed; platform reads whichever is set)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Analytics (optional; events are no-op when unset)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
